#!/bin/bash
# pebble — build, install, run, and update the Pebble app.
#   ./pebble install    raw checkout → signed app in ~/Applications (+ this CLI on PATH)
#   pebble update       pull the latest from GitHub, rebuild, swap the live app
#   pebble run          launch the installed app
#   pebble test         run the golden test suite
set -euo pipefail

# resolve symlinks (the PATH install is a symlink to this script) so REPO is
# the real checkout, not the bin dir the symlink lives in
SRC="${BASH_SOURCE[0]}"
while [ -L "$SRC" ]; do
    SRC_DIR="$(cd "$(dirname "$SRC")" && pwd)"
    SRC="$(readlink "$SRC")"
    [[ "$SRC" != /* ]] && SRC="$SRC_DIR/$SRC"
done
REPO="$(cd "$(dirname "$SRC")" && pwd)"
APP_NAME="Pebble"
APP_DIR="$HOME/Applications"
APP="$APP_DIR/$APP_NAME.app"
BOLD=$'\033[1m'; GREEN=$'\033[32m'; YELLOW=$'\033[33m'; RESET=$'\033[0m'

say()  { echo "${BOLD}${GREEN}==>${RESET}${BOLD} $*${RESET}"; }
warn() { echo "${BOLD}${YELLOW}warning:${RESET} $*"; }
die()  { echo "${BOLD}error:${RESET} $*" >&2; exit 1; }

need_swift() {
    # `command -v swift` always succeeds on macOS (the OS ships a shim), so
    # gate on the actual developer-tools install instead
    xcode-select -p >/dev/null 2>&1 || die "Xcode command-line tools not found. Install them with:  xcode-select --install"
}

build() {
    say "Building Pebble (release)…"
    # not a terminal (CI, piped): plain passthrough
    if [ ! -t 1 ]; then
        (cd "$REPO" && swift build -c release)
        return
    fi
    # release mode compiles the whole engine as one optimized unit and SwiftPM
    # prints nothing for minutes — spin so it doesn't look frozen
    local log; log="$(mktemp /tmp/pebble-build.XXXXXX)"
    (cd "$REPO" && swift build -c release >"$log" 2>&1) &
    local pid=$!
    trap 'kill "$pid" 2>/dev/null; printf "\r\033[K"; exit 130' INT TERM
    local frames='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏' i=0 start=$SECONDS last=""
    while kill -0 "$pid" 2>/dev/null; do
        last="$(tail -n 1 "$log" 2>/dev/null | tr -d '\r')"
        printf '\r\033[K  %s%s%s %3ds  %.70s' "$GREEN" "${frames:$((i % 10)):1}" "$RESET" "$((SECONDS - start))" "${last:-warming up…}"
        i=$((i + 1))
        sleep 0.12
    done
    trap - INT TERM
    printf '\r\033[K'
    if wait "$pid"; then
        echo "  ${GREEN}✓${RESET} built in $((SECONDS - start))s"
        rm -f "$log"
    else
        cat "$log"
        rm -f "$log"
        die "build failed — full output above"
    fi
}

bundle() {
    say "Assembling $APP_NAME.app…"
    local stage="$REPO/dist/$APP_NAME.app"
    rm -rf "$stage"
    mkdir -p "$stage/Contents/MacOS" "$stage/Contents/Resources"
    cp "$REPO/packaging/Info.plist"     "$stage/Contents/Info.plist"
    cp "$REPO/packaging/AppIcon.icns"   "$stage/Contents/Resources/"
    # explicit list — only ship the assets the app actually loads
    cp "$REPO/packaging/logo.png"       "$stage/Contents/Resources/"
    cp "$REPO/packaging/title-bg.png"   "$stage/Contents/Resources/"
    cp "$REPO/packaging/"*.zip          "$stage/Contents/Resources/" 2>/dev/null || true
    # the Faithful license must travel with the pack (their requirement #6)
    cp "$REPO/packaging/FAITHFUL-LICENSE.txt" "$stage/Contents/Resources/" 2>/dev/null || true
    cp "$REPO/.build/release/Pebble"    "$stage/Contents/MacOS/Pebble"
    codesign --force --sign - "$stage" >/dev/null 2>&1 || warn "codesign failed — the app may trip Gatekeeper"
}

deploy() {
    say "Installing to ${APP} ..."
    mkdir -p "$APP_DIR"
    rm -rf "$APP"
    cp -R "$REPO/dist/$APP_NAME.app" "$APP"
}

link_cli() {
    for bin in /opt/homebrew/bin /usr/local/bin; do
        if [ -d "$bin" ] && [ -w "$bin" ]; then
            ln -sf "$REPO/pebble" "$bin/pebble"
            say "CLI linked: ${bin}/pebble → you can now run 'pebble update' from anywhere"
            return
        fi
    done
    warn "couldn't find a writable bin dir — run pebble via $REPO/pebble (or add it to your PATH)"
}

cmd_install() {
    need_swift
    build
    bundle
    deploy
    # drop the staging copy — Spotlight indexes it and you end up with
    # "two Pebbles" in Launchpad
    rm -rf "$REPO/dist"
    link_cli
    say "Done. Launch with:  pebble run   (or open ~/Applications/$APP_NAME.app)"
}

cmd_update() {
    [ -d "$REPO/.git" ] || die "$REPO is not a git checkout — 'pebble update' needs one (re-clone from GitHub, or just run: pebble install)"
    say "Pulling latest…"
    (cd "$REPO" && git pull --ff-only) || die "git pull failed — if you have local changes, commit/stash them; if upstream history changed, run: git fetch origin && git reset --hard origin/main"
    exec "$REPO/pebble" install
}

cmd_run()  { open "$APP" 2>/dev/null || die "Pebble isn't installed yet — run: pebble install"; }
cmd_test() { need_swift; (cd "$REPO" && swift run -c release pebsmoke); }

case "${1:-}" in
    install) cmd_install ;;
    update)  cmd_update ;;
    run)     cmd_run ;;
    test)    cmd_test ;;
    *)
        echo "${BOLD}pebble${RESET} — one-command install for the Pebble app"
        echo
        echo "  ./pebble install    build from source and install ~/Applications/$APP_NAME.app"
        echo "  pebble update       pull the latest version and update the live app"
        echo "  pebble run          launch Pebble"
        echo "  pebble test         run the golden test suite"
        ;;
esac
